# Skill Runner environment

# LiteLLM proxy (used to drive LLM + MCP tool calls)
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=sk-homeai-litellm-master-key
EXECUTION_MODEL=gpt-4o-mini

# GitHub token for fetching private skill repos (optional, leave empty for public)
GITHUB_TOKEN=

# Skills registry path (mounted via docker-compose volume)
SKILLS_REGISTRY_PATH=/app/skills/registry.yaml

# MCP auth tokens – one per skill.
# Pattern: {SKILL_ID_UPPERCASED_UNDERSCORED}_MCP_TOKEN
# e.g. raindrop-io → RAINDROP_IO_MCP_TOKEN
RAINDROP_IO_MCP_TOKEN=your-raindrop-mcp-bearer-token-here
